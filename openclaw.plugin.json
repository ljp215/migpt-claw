{
  "id": "migpt-claw",
  "name": "MiGPT Channel",
  "description": "小米小爱音箱 OpenClaw Channel 插件",
  "channels": ["migpt"],
  "skills": ["./skills/migpt-volume"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "description": "是否启用频道",
        "default": false
      },
      "userId": {
        "type": "string",
        "description": "小米账号 ID"
      },
      "password": {
        "type": "string",
        "description": "小米账号密码"
      },
      "passToken": {
        "type": "string",
        "description": "小米 PassToken（可选，如果提供则不需要密码）"
      },
      "devices": {
        "type": "array",
        "items": { "type": "string" },
        "description": "设备名称列表"
      },
      "systemPrompt": {
        "type": "string",
        "description": "系统提示词，用于定制 AI 在音箱场景下的行为规范"
      },
      "heartbeat": {
        "type": "number",
        "description": "消息轮询间隔（毫秒）",
        "default": 1000
      },
      "speakerControl": {
        "type": "string",
        "enum": ["mina", "miot"],
        "description": "音箱控制方式"
      },
      "ttsCommand": {
        "type": "array",
        "items": { "type": "number" },
        "minItems": 2,
        "maxItems": 2,
        "description": "MIoT TTS 播报动作坐标 [siid, aiid]（仅 miot 方式生效；不配置时按型号自动探测）"
      },
      "announceOnStart": {
        "type": "boolean",
        "description": "启动时是否播报上线文案",
        "default": false
      },
      "startupMessage": {
        "type": "string",
        "description": "上线播报文案",
        "default": "您的小龙虾已上线，随时为您服务"
      },
      "acknowledgeOnReceive": {
        "type": "boolean",
        "description": "收到消息时是否回复收到",
        "default": false
      },
      "receiveMessage": {
        "type": "string",
        "description": "收到消息回复文案",
        "default": "收到，处理中"
      },
      "debug": {
        "type": "boolean",
        "description": "调试模式：打印设备列表等详细日志",
        "default": false
      },
      "timeout": {
        "type": "number",
        "description": "网络请求超时时长（毫秒）"
      },
      "streaming": {
        "type": "boolean",
        "description": "启用流式 TTS（长文本分块播放）",
        "default": true
      },
      "textChunkLimit": {
        "type": "number",
        "description": "TTS 文本分块长度（汉字）",
        "default": 200
      },
      "ttsSpeed": {
        "type": "number",
        "minimum": 0.5,
        "maximum": 2,
        "description": "TTS 语速（0.5-2.0）"
      },
      "volume": {
        "type": "number",
        "minimum": 6,
        "maximum": 100,
        "description": "默认音量（6-100）"
      },
      "defaultAccount": {
        "type": "string",
        "description": "默认账户 ID"
      },
      "devicePolicy": {
        "type": "string",
        "enum": ["pairing", "allowlist", "open"],
        "description": "设备访问策略"
      },
      "allowFrom": {
        "type": "array",
        "items": { "type": ["string", "number"] },
        "description": "允许的设备名称白名单"
      },
      "accounts": {
        "type": "object",
        "additionalProperties": { "type": "object" },
        "description": "多账号配置：{ 账号ID: 账户配置 }，账户配置字段与顶层同构（userId/password/passToken/devices/speakerControl/ttsCommand 等），未设置的字段继承顶层"
      }
    }
  },
  "uiHints": {
    "userId": {
      "label": "小米账号 ID",
      "placeholder": "请输入小米账号"
    },
    "password": {
      "label": "密码",
      "sensitive": true,
      "placeholder": "请输入小米账号密码"
    },
    "passToken": {
      "label": "PassToken",
      "sensitive": true,
      "placeholder": "可选，如果提供则不需要密码"
    },
    "devices": {
      "label": "设备列表",
      "placeholder": "客厅音箱，卧室音箱"
    },
    "systemPrompt": {
      "label": "系统提示词",
      "placeholder": "自定义 AI 在音箱场景下的行为规范"
    },
    "heartbeat": {
      "label": "轮询间隔",
      "placeholder": "1000"
    },
    "speakerControl": {
      "label": "控制方式",
      "placeholder": "mina 或 miot"
    },
    "ttsCommand": {
      "label": "TTS 动作 [siid, aiid]",
      "placeholder": "[3, 1]，留空则按型号自动探测",
      "description": "仅 miot 控制方式生效；播报无声时按 README 用 micli 查询后填写"
    },
    "announceOnStart": {
      "label": "启动时播报",
      "description": "启用后，音箱启动时会播报上线文案"
    },
    "startupMessage": {
      "label": "上线文案",
      "placeholder": "您的小龙虾已上线，随时为您服务"
    },
    "acknowledgeOnReceive": {
      "label": "收到消息回复",
      "description": "启用后，收到消息时会播放提示音"
    },
    "receiveMessage": {
      "label": "回复文案",
      "placeholder": "收到，处理中"
    },
    "enabled": {
      "label": "启用频道",
      "description": "是否启用小爱音箱频道"
    },
    "debug": {
      "label": "调试模式",
      "description": "启用后打印设备列表等详细日志"
    },
    "timeout": {
      "label": "请求超时",
      "placeholder": "毫秒"
    },
    "streaming": {
      "label": "流式播报",
      "description": "长文本分块播放，降低延迟"
    },
    "textChunkLimit": {
      "label": "分块长度",
      "placeholder": "200"
    },
    "ttsSpeed": {
      "label": "TTS 语速",
      "placeholder": "0.5-2.0"
    },
    "volume": {
      "label": "默认音量",
      "placeholder": "6-100"
    },
    "defaultAccount": {
      "label": "默认账户",
      "placeholder": "账户 ID"
    },
    "devicePolicy": {
      "label": "设备访问策略",
      "placeholder": "pairing / allowlist / open"
    },
    "allowFrom": {
      "label": "设备白名单",
      "placeholder": "允许的设备名称列表"
    },
    "accounts": {
      "label": "多账号配置",
      "description": "键为账号 ID，值为与顶层同构的账户配置，未设置字段继承顶层"
    }
  }
}
